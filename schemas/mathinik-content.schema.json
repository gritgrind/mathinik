{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathinik.local/schemas/mathinik-content.schema.json",
  "title": "Mathinik Content Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "packId", "title", "version", "grades"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "packId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "minLength": 2 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "grades": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/grade" }
    }
  },
  "$defs": {
    "grade": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "grade", "title", "skills"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "grade": { "type": "integer", "minimum": 1, "maximum": 3 },
        "title": { "type": "string", "minLength": 1 },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skill" }
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "title", "domain", "lessons"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "domain": {
          "type": "string",
          "enum": [
            "number-sense",
            "addition-subtraction",
            "multiplication-foundations",
            "word-problems"
          ]
        },
        "description": { "type": "string" },
        "lessons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lesson" }
        }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "title", "goal", "activities"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "estimatedMinutes": { "type": "integer", "minimum": 1, "maximum": 15 },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "unlock": { "$ref": "#/$defs/unlock" },
        "reward": { "$ref": "#/$defs/reward" },
        "activities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/activity" }
        }
      }
    },
    "unlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiresLessonIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "uniqueItems": true
        },
        "minStars": { "type": "integer", "minimum": 0, "maximum": 3 },
        "minMastery": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "reward": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starsAvailable": { "type": "integer", "minimum": 1, "maximum": 3 },
        "badgeId": { "type": "string" },
        "mapNodeId": { "type": "string" }
      }
    },
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "prompt", "difficulty", "success", "content"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "equation-builder",
            "object-manipulation",
            "multiple-choice",
            "numeric-input"
          ]
        },
        "prompt": { "type": "string", "minLength": 1 },
        "intro": { "type": "string" },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "masteryWeight": { "type": "number", "minimum": 0, "maximum": 5 },
        "hint": { "$ref": "#/$defs/supportText" },
        "explanation": { "$ref": "#/$defs/supportText" },
        "followUp": { "$ref": "#/$defs/followUp" },
        "audio": { "$ref": "#/$defs/audio" },
        "ui": { "$ref": "#/$defs/ui" },
        "success": { "$ref": "#/$defs/success" },
        "content": {
          "oneOf": [
            { "$ref": "#/$defs/equationBuilderContent" },
            { "$ref": "#/$defs/objectManipulationContent" },
            { "$ref": "#/$defs/multipleChoiceContent" },
            { "$ref": "#/$defs/numericInputContent" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "equation-builder" } } },
          "then": { "properties": { "content": { "$ref": "#/$defs/equationBuilderContent" } } }
        },
        {
          "if": { "properties": { "type": { "const": "object-manipulation" } } },
          "then": { "properties": { "content": { "$ref": "#/$defs/objectManipulationContent" } } }
        },
        {
          "if": { "properties": { "type": { "const": "multiple-choice" } } },
          "then": { "properties": { "content": { "$ref": "#/$defs/multipleChoiceContent" } } }
        },
        {
          "if": { "properties": { "type": { "const": "numeric-input" } } },
          "then": { "properties": { "content": { "$ref": "#/$defs/numericInputContent" } } }
        }
      ]
    },
    "supportText": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "visualCue": { "type": "string" }
      }
    },
    "followUp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "prompt"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["confirm-representation", "second-representation", "guided-retry"]
        },
        "prompt": { "type": "string", "minLength": 1 }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "successSfx": { "type": "string" },
        "errorSfx": { "type": "string" },
        "rewardSfx": { "type": "string" }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theme": { "type": "string" },
        "snapMode": {
          "type": "string",
          "enum": ["forgiving", "strict"]
        },
        "showUndo": { "type": "boolean" }
      }
    },
    "success": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "stars"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["exact-match", "set-match", "numeric-match", "choice-match"]
        },
        "stars": { "type": "integer", "minimum": 1, "maximum": 3 }
      }
    },
    "equationBuilderContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "leftSide", "rightSide", "palette", "validAnswers"],
      "properties": {
        "kind": { "const": "equation-builder" },
        "leftSide": { "$ref": "#/$defs/tokenSequence" },
        "rightSide": { "$ref": "#/$defs/tokenSequence" },
        "palette": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/token" }
        },
        "validAnswers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/equationAnswer" }
        }
      }
    },
    "objectManipulationContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "scene", "task", "validAnswers"],
      "properties": {
        "kind": { "const": "object-manipulation" },
        "scene": { "$ref": "#/$defs/scene" },
        "task": { "type": "string", "minLength": 1 },
        "validAnswers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/objectAnswer" }
        }
      }
    },
    "multipleChoiceContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "choices", "correctChoiceIds"],
      "properties": {
        "kind": { "const": "multiple-choice" },
        "choices": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/choice" }
        },
        "correctChoiceIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "numericInputContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "acceptedAnswers"],
      "properties": {
        "kind": { "const": "numeric-input" },
        "acceptedAnswers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "type": "integer" },
              { "type": "number" },
              { "type": "string" }
            ]
          }
        }
      }
    },
    "tokenSequence": {
      "type": "array",
      "items": { "$ref": "#/$defs/tokenRef" }
    },
    "token": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "label"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["number", "operator", "object-group", "equals"]
        },
        "label": { "type": "string", "minLength": 1 },
        "value": {
          "oneOf": [
            { "type": "integer" },
            { "type": "number" },
            { "type": "string" }
          ]
        },
        "visual": { "type": "string" }
      }
    },
    "tokenRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tokenId"],
      "properties": {
        "tokenId": { "type": "string" }
      }
    },
    "equationAnswer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "right"],
      "properties": {
        "left": {
          "type": "array",
          "items": { "type": "string" }
        },
        "right": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objects"],
      "properties": {
        "background": { "type": "string" },
        "objects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sceneObject" }
        }
      }
    },
    "sceneObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "count"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "count": { "type": "integer", "minimum": 1 },
        "groupable": { "type": "boolean" }
      }
    },
    "objectAnswer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expectedCount": { "type": "integer", "minimum": 0 },
        "expectedGroups": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "matchTargetId": { "type": "string" }
      },
      "minProperties": 1
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "visual": { "type": "string" }
      }
    }
  }
}
